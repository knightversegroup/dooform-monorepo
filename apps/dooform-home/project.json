{
  "name": "dooform-home",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/dooform-home/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/dooform-home"],
      "options": {
        "command": "astro build",
        "cwd": "apps/dooform-home"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "astro dev",
        "cwd": "apps/dooform-home"
      }
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": {
        "command": "astro preview",
        "cwd": "apps/dooform-home"
      }
    },
    "check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "astro check",
        "cwd": "apps/dooform-home"
      }
    },
    "sync": {
      "executor": "nx:run-commands",
      "options": {
        "command": "astro sync",
        "cwd": "apps/dooform-home"
      }
    }
  },
  "tags": []
}
